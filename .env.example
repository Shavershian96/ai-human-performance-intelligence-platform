# AI Human Performance Platform - Environment Configuration
# 12-Factor App: Config via environment. Copy to .env and override.

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=perf_user
POSTGRES_PASSWORD=perf_password
POSTGRES_DB=performance_db

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Microservices: ML Trainer ---
# Set USE_ML_TRAINER_SERVICE=true when running ml-trainer as separate service
USE_ML_TRAINER_SERVICE=false
ML_TRAINER_URL=http://ml-trainer:8080
ML_TRAINER_TIMEOUT_SECONDS=300
ML_TRAINER_RETRY_ATTEMPTS=3
ML_TRAINER_RETRY_BASE_DELAY_SECONDS=0.5
ML_TRAINER_CIRCUIT_BREAKER_FAILURES=5
ML_TRAINER_CIRCUIT_BREAKER_RESET_SECONDS=60

# --- Model Storage (shared volume in K8s/Docker) ---
MODEL_PATH=models/performance_model.pkl
FEATURE_SCALER_PATH=models/feature_scaler.pkl

# --- Observability (optional) ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=predictions-api
OTEL_ENDPOINT=http://localhost:4317

# --- Dashboard ---
API_URL=http://localhost:8000
PROMETHEUS_URL=http://localhost:9090
